# ============================================
# Crypto Wallet Analyzer - Environment Variables
# ============================================

# Node.js Backend Configuration
NODE_ENV=development
PORT=5000
MONGODB_URI=mongodb://localhost:27017/crypto-wallet

# External API Keys (Get from respective providers)
GOLDRUSH_API_KEY=your_covalent_goldrush_key_here
TATUM_API_KEY=your_tatum_key_here

# Python Server Configuration
PYTHON_SERVER_URL=http://localhost:8000

# Frontend Configuration
VITE_API_URL=http://localhost:5000

# JWT Secret (Generate a secure random string)
JWT_SECRET=your_secure_jwt_secret_here

# Optional: Redis Configuration (for caching - future feature)
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=

# Optional: Logging
LOG_LEVEL=info
